<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delicious Bites Restaurant</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background: #f8f8f8;
    }
    header {
      background: #b22222;
      color: white;
      padding: 20px;
      text-align: center;
    }
    nav {
      background: #333;
      padding: 10px;
      text-align: center;
    }
    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }
    nav a:hover {
      color: #ffcc00;
    }
    section {
      padding: 40px;
      text-align: center;
    }
    .menu {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
    }
    .menu-item {
      background: white;
      margin: 15px;
      padding: 20px;
      border-radius: 8px;
      width: 250px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    footer {
      background: #333;
      color: white;
      text-align: center;
      padding: 15px;
      margin-top: 20px;
    }
    form input, form textarea {
      width: 80%;
      padding: 10px;
      margin: 10px 0;
      border-radius: 5px;
      border: 1px solid #ccc;
    }
    form button {
      background: #b22222;
      color: white;
      padding: 10px 20px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }
    form button:hover {
      background: #ffcc00;
      color: black;
    }
  </style>
</head>
<body>

  <header>
    <h1>Delicious Bites</h1>
    <p>Where Taste Meets Tradition</p>
  </header>

  <nav>
    <a href="#menu">Menu</a>
    <a href="#about">About Us</a>
    <a href="#contact">Contact</a>
  </nav>

  <section id="menu">
    <h2>Our Menu</h2>
    <div class="menu">
      <div class="menu-item">
        <h3>Margherita Pizza</h3>
        <p>Classic cheese and tomato pizza.</p>
        <p><strong>$10</strong></p>
      </div>
      <div class="menu-item">
        <h3>Pasta Alfredo</h3>
        <p>Creamy white sauce pasta.</p>
        <p><strong>$12</strong></p>
      </div>
      <div class="menu-item">
        <h3>Veggie Burger</h3>
        <p>Fresh grilled veggie patty with fries.</p>
        <p><strong>$8</strong></p>
      </div>
    </div>
  </section>

  <section id="about">
    <h2>About Us</h2>
    <p>At Delicious Bites, we serve freshly made dishes inspired by traditional recipes. Our chefs use the finest ingredients to bring you flavors that feel like home.</p>
  </section>

  <section id="contact">
    <h2>Contact Us</h2>
    <form>
      <input type="text" placeholder="Your Name" required><br>
      <input type="email" placeholder="Your Email" required><br>
      <textarea placeholder="Your Message" rows="5" required></textarea><br>
      <button type="submit">Send Message</button>
    </form>
  </section>

  <footer>
    <p>&copy; 2026 Delicious Bites Restaurant | All Rights Reserved</p>
  </footer>

</body>
</html>
