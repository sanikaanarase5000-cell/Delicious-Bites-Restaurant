<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delicious Bites Restaurant</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: #fff8f0;
        }

        /* Navbar */
        nav {
            background-color: #8B0000;
            color: white;
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        nav h1 {
            font-size: 24px;
        }

        nav ul {
            list-style: none;
            display: flex;
            gap: 20px;
        }

        nav ul li {
            cursor: pointer;
        }

        nav ul li:hover {
            text-decoration: underline;
        }

        /* Hero Section */
        .hero {
            height: 90vh;
            background: url('https://images.unsplash.com/photo-1555396273-367ea4eb4db5') no-repeat center/cover;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
        }

        .hero h2 {
            font-size: 50px;
            background: rgba(0,0,0,0.6);
            padding: 20px;
            border-radius: 10px;
        }

        /* Section */
        section {
            padding: 50px 20px;
            text-align: center;
        }

        .menu {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .card {
            background: white;
            width: 250px;
            border-radius: 10px;
            box-shadow: 0px 4px 10px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        .card img {
            width: 100%;
        }

        .card h3 {
            margin: 10px 0;
        }

        .card p {
            padding: 0 10px 10px;
        }

        /* Contact */
        .contact {
            background-color: #f4f4f4;
        }

        footer {
            background-color: #8B0000;
            color: white;
            text-align: center;
            padding: 15px;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav>
        <h1>Delicious Bites</h1>
        <ul>
            <li>Home</li>
            <li>Menu</li>
            <li>About</li>
            <li>Contact</li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <div class="hero">
        <h2>Welcome to Delicious Bites 🍽️</h2>
    </div>

    <!-- Menu Section -->
    <section>
        <h2>Our Popular Dishes</h2>
        <div class="menu">

            <div class="card">
                <img src="https://images.unsplash.com/photo-1600891964599-f61ba0e24092">
                <h3>Pizza</h3>
                <p>Cheesy and delicious Italian pizza.</p>
            </div>

            <div class="card">
                <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1">
                <h3>Burger</h3>
                <p>Juicy burgers with fresh ingredients.</p>
            </div>

            <div class="card">
                <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c">
                <h3>Salad</h3>
                <p>Healthy and fresh green salad.</p>
            </div>

        </div>
    </section>

    <!-- About Section -->
    <section>
        <h2>About Us</h2>
        <p>At Delicious Bites, we serve fresh, tasty, and hygienic food made with love. Our goal is to give you the best dining experience.</p>
    </section>

    <!-- Contact Section -->
    <section class="contact">
        <h2>Contact Us</h2>
        <p>Email: deliciousbites@email.com</p>
        <p>Phone: +91 98765 43210</p>
        <p>Location: Belapur, Navi Mumbai</p>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 Delicious Bites Restaurant</p>
    </footer>

</body>
</html>
